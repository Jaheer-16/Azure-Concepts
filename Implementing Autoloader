STEP1:-CREATE CATALOG 
%sql
CREATE CATALOG IF NOT EXISTS main;

USE CATALOG main;

CREATE SCHEMA IF NOT EXISTS default;

USE SCHEMA default;

CREATE VOLUME IF NOT EXISTS autoloader_demo;

HERE VOLUME IS TO SAVE schema_location AND checkpoint_location INFO


STEP2:-CREATE LOCATIONS
catalog_name = "main"
schema_name = "default"
volume_name =  "autoloader_demo"
schema_location = f"/Volumes/main/default/autoloader_demo/schema/customer_csv"
checkpoint_location = f"/Volumes/main/default/autoloader_demo/checkpoint/customer_csv"
source_path=f"/Volumes/main/default/autoloader_demo/source/customer_csv"
target_table = f"{catalog_name}.{schema_name}.customer_bronze"

print("Source Path:", source_path)
print("Schema Location:", schema_location)
print("Checkpoint Location:", checkpoint_location)
print("Target Table:", target_table)

base_path = f"/Volumes/{catalog_name}/{schema_name}/{volume_name}"

STEP3:-MAIN CODE
raw_df = (
    spark.readStream
    .format("cloudFiles")
    .option("cloudFiles.format", "csv")
    .option("cloudFiles.schemaLocation", schema_location)
	.option("cloudFiles.useManagedFileEvents", "true")
    .option("header", "true")
    .option("inferColumnTypes", "true")
    .load(source_path)
)

from pyspark.sql.functions import current_timestamp, input_file_name

bronze_df = (
    raw_df
    .withColumn("ingestion_time", current_timestamp())
)

query = (
    bronze_df.writeStream
    .format("delta")
    .option("checkpointLocation", checkpoint_location)
    .option("mergeSchema", "true")
    .outputMode("append")
    .trigger(availableNow=True)
    .toTable(target_table)
)

query.awaitTermination();

